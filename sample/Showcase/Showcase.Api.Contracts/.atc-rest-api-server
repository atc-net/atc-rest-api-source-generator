{
    "validateSpecificationStrategy": "Strict",
    "includeDeprecated": false,
    "useMinimalApiPackage": "enabled",
    "useValidationFilter": "enabled",
    "useGlobalErrorHandler": "enabled",
    "generateWebhooks": true,
    "healthChecks": {
        "enabled": true,
        "includeLiveness": true,
        "includeReadiness": true,
        "security": "apiKey",
        "apiKeyQueryParameterName": "api-key",
        "apiKeyHeaderName": "X-Health-Api-Key"
    }
}